# ─────────────────────────────────────────────────────────────────
# Siara Dental SaaS — Backend Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development               # development | production

# Auth (JWT)
AUTH_SECRET=change-me-to-a-random-32+-char-string-in-production
TOKEN_TTL_HOURS=12                 # How long login sessions last (in hours)

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# PostgreSQL (Supabase or any Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Mistral AI (for prescription suggestions and clinic AI chat)
# Get from: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Resend (for email notifications — welcome, prescriptions, invoices, backups)
# Get from: https://resend.com/
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_TO_EMAIL=admin@yourdomain.com   # Where backup emails are sent
